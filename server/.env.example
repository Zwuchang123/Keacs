KEACS_AGENT_DOMAIN=agent.example.com
KEACS_MODEL_PROVIDER=openai_compatible
KEACS_MODEL_BASE_URL=https://api.minimax.io/v1
KEACS_MODEL_NAME=MiniMax-M2.7
KEACS_MODEL_REASONING_SPLIT=true
KEACS_MODEL_API_KEY=replace-with-server-env-secret
KEACS_RATE_LIMIT_PER_MINUTE=20
KEACS_RATE_LIMIT_PER_DAY=200
KEACS_MAX_MESSAGE_LENGTH=1000
KEACS_MAX_CONTEXT_ITEMS=200
